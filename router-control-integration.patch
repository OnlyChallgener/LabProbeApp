+@Composable
+fun DeviceRealtimeStatusBar(d: DeviceItem) {
+    if (!d.online) return
+    val upload = formatDeviceRealtimeRate(d.realtimeUploadBytes)
+    val download = formatDeviceRealtimeRate(d.realtimeDownloadBytes)
+    Surface(
+        modifier = Modifier.fillMaxWidth(),
+        shape = RoundedCornerShape(17.dp),
+        color = Color(0xFF2563EB).copy(alpha = .05f),
+        border = BorderStroke(1.dp, Color(0xFF2563EB).copy(alpha = .10f))
+    ) {
+        Row(
+            Modifier.fillMaxWidth().padding(horizontal = 9.dp, vertical = 5.dp),
+            verticalAlignment = Alignment.CenterVertically
+        ) {
+            Text("实时", fontSize = 10.sp, fontWeight = FontWeight.Black, color = MaterialTheme.colorScheme.onSurface.copy(alpha = .55f))
+            Spacer(Modifier.width(7.dp))
+            Text("↑ $upload", fontSize = 10.5.sp, fontWeight = FontWeight.Bold, color = Color(0xFFF59E0B), maxLines = 1)
+            Spacer(Modifier.width(9.dp))
+            Text("↓ $download", fontSize = 10.5.sp, fontWeight = FontWeight.Bold, color = Color(0xFF06B6D4), maxLines = 1)
+            Spacer(Modifier.weight(1f))
+            Text("连接 ${d.connectionCount}", fontSize = 10.3.sp, fontWeight = FontWeight.Black, color = MaterialTheme.colorScheme.onSurface.copy(alpha = .62f), maxLines = 1)
+        }
+    }
+}
+
+private fun formatDeviceRealtimeRate(bytesPerSecond: Long): String {
+    val bits = bytesPerSecond.coerceAtLeast(0L) * 8.0
+    return when {
+        bits < 1_000.0 -> "${bits.toLong()} bps"
+        bits < 1_000_000.0 -> String.format(Locale.US, "%.0f Kbps", bits / 1_000.0)
+        else -> String.format(Locale.US, "%.2f Mbps", bits / 1_000_000.0)
+    }
+}
