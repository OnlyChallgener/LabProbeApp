+
+private fun firstLong(root: JSONObject, vararg keys: String): Long {
+    keys.forEach { key ->
+        if (!root.has(key) || root.isNull(key)) return@forEach
+        val raw = root.opt(key)
+        val value = when (raw) {
+            is Number -> raw.toLong()
+            is String -> raw.trim().toDoubleOrNull()?.toLong()
+            else -> null
+        }
+        if (value != null) return value.coerceAtLeast(0L)
+    }
+    return 0L
+}
 
